{
  "name": "@algodev-studio/algopay",
  "version": "0.1.0-alpha.2",
  "description": "AlgoPay TypeScript SDK — Algorand agent payments (USDC ASA, x402-ready client)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@x402-avm/avm": "~2.6.1",
    "@x402-avm/core": "~2.6.1",
    "@x402-avm/fetch": "^2.6.1",
    "algosdk": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Algodev-Studio/algopay-sdk.git"
  },
  "keywords": [
    "algopay",
    "algorand",
    "x402",
    "usdc",
    "agent"
  ]
}
