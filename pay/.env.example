# Transaction pooler (port 6543) — use for runtime queries on Vercel/serverless
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (port 5432) — use for Prisma migrations; IPv4-compatible alternative to direct host
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"
SESSION_SECRET="change-me-min-32-chars-for-jwt-signing-please"
ALGOPAY_VAULT_MASTER_KEY="base64-encoded-32-bytes-use-openssl-rand"
NEXT_PUBLIC_APP_NAME="AlgoPay"

# Algorand (agent pay + dashboard reads)
ALGOPAY_NETWORK=algorand-testnet
ALGOD_URL=
INDEXER_URL=
ALGOPAY_USDC_ASA_ID=

# Optional: Redis for distributed guard counters (future parity with Python Redis storage)
# REDIS_URL=redis://localhost:6379
